        completed: 1,
        resources: [
          { resource_type: 'pdf', phase: 'pre', title: `${studentName}-${courseName}-璁蹭箟`, url: '/uploads/' + SAMPLE_PDF_NAME, video_id: null },
          { resource_type: 'video', phase: 'main', title: `${courseName} 鏂规硶璁茶В`, url: null, video_id: `video_${studentId}_core` },
