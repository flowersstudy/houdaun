DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=student_teacher

JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=7d

PORT=3000

# PDF 上传文件目录。生产环境建议配置到项目目录外的固定磁盘路径。
# Windows 示例：D:\data\student-teacher\uploads
# Linux 示例：/data/student-teacher/uploads
# 不配置时默认使用项目内 uploads 目录。
# UPLOADS_DIR=

WX_APPID=your_wechat_appid
WX_SECRET=your_wechat_secret

# Railway MySQL 部署时也可直接使用平台注入的以下变量
# MYSQLHOST=
# MYSQLPORT=
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLDATABASE=
